# Git
.git
.gitignore
.gitattributes

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Django dev artifacts
*.log
local_settings.py
# db.sqlite3
db.sqlite3-journal

# Collected static (rebuilt inside the container)
staticfiles/
static_root/

# Media uploads (should come from a volume, not the image)
media/

