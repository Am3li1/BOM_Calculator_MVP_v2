.coverage
.pytest_cache/
htmlcov/
coverage.xml
*.cover

# CI / editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Docker files themselves (no need to copy into the image)
Dockerfile
.dockerignore
docker-compose*.yml

# Render-specific
build.sh
render.yaml

# Secrets / env files – NEVER bake these into an image
.env
.env.*
!.env.example