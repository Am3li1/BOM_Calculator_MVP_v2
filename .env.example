# .env.example
# Copy to .env and fill in real values. Never commit .env.

# ── Django ────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────
# SQLite phase: leave DATABASE_URL blank or omit it entirely.
# PostgreSQL phase: uncomment and fill in.
# DATABASE_URL=postgres://django:password@db:5432/bom_costing

# ── Static files ──────────────────────────────────────────
# Must match STATIC_ROOT in settings.py
STATIC_ROOT=/app/staticfiles

# ── Gunicorn tuning (optional) ────────────────────────────
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info

# ── PostgreSQL credentials (used by the db service) ───────
# POSTGRES_DB=bom_costing
# POSTGRES_USER=django
# POSTGRES_PASSWORD=replace-with-strong-password